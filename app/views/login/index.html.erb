
<div>
    <h1>Campus Resource Assistant</h1>
    <%= form_with url: "/login", method: :post, data: { turbo: false } do %>
        <div>
            <%= label_tag :email %><br>
            <%= text_field_tag :email %><br>
        </div>
        <div>
            <%= label_tag :password %><br>
            <%= text_field_tag :password %><br>
        </div>

        <% if flash[:alert] %>
            <div style="color: red;"><%= flash[:alert] %></div>
        <% end %>
        <div>
            <%= submit_tag "Login" %><br>
        </div>
    <% end %>
</div>