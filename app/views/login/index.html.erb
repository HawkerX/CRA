
<div 
    class="card"
    style="
        margin: auto; 
        margin-top: 10%;
        width: fit-content; 
        display: flex; 
        flex-direction: column; 
        align-items: center;
        ">
    <h2>Campus<br>Resource<br>Assistant</h2>
    <%= form_with url: "/login", method: :post, style: "width: fit-content;", data: { turbo: false } do %>
        <%= text_field_tag :email, nil, placeholder: "email", class: "input" %><br>
        <%= password_field_tag :password, nil, placeholder: "password", class: "input" %><br>
        <% if flash[:alert] %>
            <div style="color: red;"><%= flash[:alert] %></div>
        <% end %>
        <%= submit_tag "Login", class: "button raised-accent-primary", style: "display: block; margin: auto;" %>
    <% end %>
</div>